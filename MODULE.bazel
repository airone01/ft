use_repo(nix_pkg, "readline", "libX11", "libXext", "libXrandr", "libXrender")

# Nix CC
git_override(
    module_name = "rules_nixpkgs_cc",
    remote = "https://github.com/tweag/rules_nixpkgs",
    commit = "cb0f9be1798131ea4336fd02b850edeeb1972680",
    strip_prefix = "toolchains/cc",
)

nix_cc = use_extension("@rules_nixpkgs_cc//extensions:toolchains.bzl", "nix_cc")
nix_cc.toolchain(
    name = "nix_toolchain",
    repository = "@nixpkgs",
)
use_repo(nix_cc, "nix_toolchain")

# Nix Rust
git_override(
    module_name = "rules_nixpkgs_rust",
    remote = "https://github.com/tweag/rules_nixpkgs",
    commit = "cb0f9be1798131ea4336fd02b850edeeb1972680",
    strip_prefix = "toolchains/rust",
)
nix_rust = use_extension("@rules_nixpkgs_rust//:rust.bzl", "nix_rust")
nix_rust.toolchain(
    name = "nix_rust_toolchain",
    repository = "@nixpkgs", 
)
use_repo(nix_rust, "nix_rust_toolchain")

register_toolchains("@nix_rust_toolchain//:all")

