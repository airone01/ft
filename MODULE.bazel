module(
    name = "ft",
    version = "1.0.0",
)

# Deps
bazel_dep(name = "rules_cc", version = "0.2.17")
bazel_dep(name = "rules_rust", version = "0.69.0")
bazel_dep(name = "hedron_compile_commands", dev_dependency = True)
bazel_dep(name = "rules_nixpkgs_core", version = "0.13.0")
bazel_dep(name = "rules_nixpkgs_cc", version = "0.13.0")
bazel_dep(name = "rules_nixpkgs_rust", version = "0.13.0")

# compile_commands.json
git_override(
    module_name = "hedron_compile_commands",
    remote = "https://github.com/xFile3160/bazel-compile-commands-extractor.git",
    branch = "7fe1eab26d2b8eeb5e1c6a2f38bddb001e3f9696",
)

# Rust
rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(edition = "2021")
use_repo(rust, "rust_toolchains")
register_toolchains("@rust_toolchains//:all")

# Nix
git_override(
    module_name = "rules_nixpkgs_core",
    remote = "https://github.com/tweag/rules_nixpkgs",
    commit = "cb0f9be1798131ea4336fd02b850edeeb1972680",
    strip_prefix = "core",
)

nix_repo = use_extension("@rules_nixpkgs_core//extensions:repository.bzl", "nix_repo")
nix_repo.flake(
    name = "nixpkgs",
    lock_file = "//:flake.lock",
)
use_repo(nix_repo, "nixpkgs")

nix_pkg = use_extension("@rules_nixpkgs_core//extensions:package.bzl", "nix_pkg")
nix_pkg.expr(
    name = "readline",
    repo = "@nixpkgs",
    attr = "pkg",
    expr = "let pkgs = import <nixpkgs> {}; in { pkg = pkgs.buildEnv { name = \"readline-merged\"; paths = [ pkgs.readline pkgs.readline.dev ]; }; }",
    build_file_content = """
package(default_visibility = ["//visibility:public"])
cc_library(
    name = "readline",
    srcs = glob(["lib/**/*.so*"]),
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
)
""",
)
nix_pkg.expr(
    name = "libX11",
    repo = "@nixpkgs",
    attr = "pkg",
    expr = "let pkgs = import <nixpkgs> {}; in { pkg = pkgs.buildEnv { name = \"libX11-merged\"; paths = [ pkgs.xorg.libX11 pkgs.xorg.libX11.dev pkgs.xorg.xorgproto ]; ignoreCollisions = true; }; }",
    build_file_content = """
package(default_visibility = ["//visibility:public"])
cc_library(
    name = "libX11",
    srcs = glob(["lib/**/*.so*"]),
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
)
""",
)
nix_pkg.expr(
    name = "libXext",
    repo = "@nixpkgs",
    attr = "pkg",
    expr = "let pkgs = import <nixpkgs> {}; in { pkg = pkgs.buildEnv { name = \"libXext-merged\"; paths = [ pkgs.xorg.libXext pkgs.xorg.libXext.dev pkgs.xorg.xorgproto ]; ignoreCollisions = true; }; }",
    build_file_content = """
package(default_visibility = ["//visibility:public"])
cc_library(
    name = "libXext",
    srcs = glob(["lib/**/*.so*"]),
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
)
""",
)
nix_pkg.expr(
    name = "libXrandr",
    repo = "@nixpkgs",
    attr = "pkg",
    expr = "let pkgs = import <nixpkgs> {}; in { pkg = pkgs.buildEnv { name = \"libXrandr-merged\"; paths = [ pkgs.xorg.libXrandr pkgs.xorg.libXrandr.dev pkgs.xorg.xorgproto ]; ignoreCollisions = true; }; }",
    build_file_content = """
package(default_visibility = ["//visibility:public"])
cc_library(
    name = "libXrandr",
    srcs = glob(["lib/**/*.so*"]),
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
)
""",
)
nix_pkg.expr(
    name = "libXrender",
    repo = "@nixpkgs",
    attr = "pkg",
    expr = "let pkgs = import <nixpkgs> {}; in { pkg = pkgs.buildEnv { name = \"libXrender-merged\"; paths = [ pkgs.xorg.libXrender pkgs.xorg.libXrender.dev pkgs.xorg.xorgproto ]; ignoreCollisions = true; }; }",
    build_file_content = """
package(default_visibility = ["//visibility:public"])
cc_library(
    name = "libXrender",
    srcs = glob(["lib/**/*.so*"]),
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
)
""",
)
